{
  "name": "shadcn-solid-components",
  "version": "0.0.0",
  "description": "{{desc_of_lib}}",
  "license": "MIT",
  "author": "vgerbot-libraries",
  "contributors": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vgerbot-libraries/shadcn-solid-components.git"
  },
  "homepage": "https://github.com/vgerbot-libraries/shadcn-solid-components#readme",
  "bugs": {
    "url": "https://github.com/vgerbot-libraries/shadcn-solid-components/issues"
  },
  "files": [
    "dist",
    "tailwind.preset.css"
  ],
  "private": false,
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index/index.js",
  "module": "./dist/index/index.js",
  "types": "./dist/index/index.d.ts",
  "browser": {},
  "exports": {
    ".": {
      "solid": "./dist/index/index.jsx",
      "import": {
        "types": "./dist/index/index.d.ts",
        "default": "./dist/index/index.js"
      }
    },
    "./accordion": {
      "solid": "./dist/accordion/index.jsx",
      "import": {
        "types": "./dist/accordion/index.d.ts",
        "default": "./dist/accordion/index.js"
      }
    },
    "./alert": {
      "solid": "./dist/alert/index.jsx",
      "import": {
        "types": "./dist/alert/index.d.ts",
        "default": "./dist/alert/index.js"
      }
    },
    "./alert-dialog": {
      "solid": "./dist/alert-dialog/index.jsx",
      "import": {
        "types": "./dist/alert-dialog/index.d.ts",
        "default": "./dist/alert-dialog/index.js"
      }
    },
    "./button": {
      "solid": "./dist/button/index.jsx",
      "import": {
        "types": "./dist/button/index.d.ts",
        "default": "./dist/button/index.js"
      }
    },
    "./lib": {
      "import": {
        "types": "./dist/lib/index.d.ts",
        "default": "./dist/lib/index.js"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "vite serve dev",
    "build": "tsup",
    "test": "concurrently pnpm:test:*",
    "test:client": "vitest",
    "test:ssr": "pnpm run test:client --mode ssr",
    "prepublishOnly": "pnpm build",
    "format": "prettier --ignore-path .gitignore -w \"src/**/*.{js,ts,json,css,tsx,jsx}\" \"dev/**/*.{js,ts,json,css,tsx,jsx}\"",
    "lint": "concurrently pnpm:lint:*",
    "lint:code": "eslint --ignore-path .gitignore --max-warnings 0 src/**/*.{js,ts,tsx,jsx}",
    "lint:types": "tsc --noEmit",
    "update-deps": "pnpm up -Li"
  },
  "peerDependencies": {
    "solid-js": "^1.6.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.21.3",
    "esbuild-plugin-solid": "^0.6.0",
    "eslint": "^8.56.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-no-only-tests": "^3.1.0",
    "jsdom": "^24.0.0",
    "prettier": "3.0.0",
    "solid-js": "^1.8.17",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.0.2",
    "tsup-preset-solid": "^2.2.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-solid": "^2.10.2",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "solid"
  ],
  "packageManager": "pnpm@9.1.1",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "cva": "1.0.0-beta.4",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0"
  },
  "typesVersions": {
    "*": {
      "accordion": [
        "./dist/accordion/index.d.ts"
      ],
      "alert": [
        "./dist/alert/index.d.ts"
      ],
      "alert-dialog": [
        "./dist/alert-dialog/index.d.ts"
      ],
      "button": [
        "./dist/button/index.d.ts"
      ],
      "lib": [
        "./dist/lib/index.d.ts"
      ]
    }
  }
}
